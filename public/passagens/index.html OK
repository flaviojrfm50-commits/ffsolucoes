async function restaurarEstadoSalvo(){
  const estado = getEstadoSalvo();
  restaurandoEstado = true;

  try{
    if(estado.tipoViagem){
      document.getElementById("tipoViagem").value = estado.tipoViagem;
    }

    if(estado.dataIda){
      document.getElementById("dataIda").value = estado.dataIda;
    }

    if(estado.dataVolta){
      document.getElementById("dataVolta").value = estado.dataVolta;
    }

    atualizarCamposData();

    document.getElementById("formaPagamento").value = estado.formaPagamento || "";
    document.getElementById("nome").value = estado.nome || "";
    document.getElementById("cpfRg").value = estado.cpfRg || "";
    document.getElementById("whatsapp").value = estado.whatsapp || "";

    codigoReservaGlobal = estado.codigoReservaGlobal || null;
    ultimoTextoRecibo = estado.ultimoTextoRecibo || "";
    pedidoPixAtual = estado.pedidoPixAtual || null;

    if(estado.viagemSelecionada){
      await selecionarViagem(estado.viagemSelecionada, true);
    }

    if(estado.infoViagemHtml){
      document.getElementById("infoViagem").innerHTML = estado.infoViagemHtml;
    }

    if(estado.valorViagemHtml){
      document.getElementById("valorViagem").innerHTML = estado.valorViagemHtml;
      if(estado.valorViagemHidden){
        document.getElementById("valorViagem").classList.add("hidden");
      }else{
        document.getElementById("valorViagem").classList.remove("hidden");
      }
    }

    if(estado.pixValorHtml){
      document.getElementById("pixValor").innerHTML = estado.pixValorHtml;
    }

    if(estado.pixQrImg){
      document.getElementById("pixQrImg").src = estado.pixQrImg;
    }

    if(estado.pixCopiaCola){
      document.getElementById("pixCopiaCola").value = estado.pixCopiaCola;
    }

    if(estado.pixBoxDisplay){
      document.getElementById("pixBox").style.display = estado.pixBoxDisplay;
    }

    if(estado.checkoutLinkHref && estado.checkoutLinkHref !== "#"){
      document.getElementById("checkoutLink").href = estado.checkoutLinkHref;
      if(estado.checkoutLinkHidden){
        document.getElementById("checkoutLink").classList.add("hidden");
      }else{
        document.getElementById("checkoutLink").classList.remove("hidden");
      }
    }

    if(estado.comprovanteVisual){
      document.getElementById("comprovanteVisual").innerHTML = estado.comprovanteVisual;
    }

    if(estado.qrReservaImg){
      document.getElementById("qrReservaImg").src = estado.qrReservaImg;
    }

    if(estado.textoRecibo){
      document.getElementById("textoRecibo").value = estado.textoRecibo;
    }

    if(estado.textoRecibo){
      const numero = String(document.getElementById("whatsapp").value || "").replace(/\D/g, "");
      const textoWhats = encodeURIComponent(estado.textoRecibo);
      if(numero){
        document.getElementById("btnWhatsRecibo").href = `https://wa.me/55${numero}?text=${textoWhats}`;
      }else{
        document.getElementById("btnWhatsRecibo").href = `https://wa.me/?text=${textoWhats}`;
      }
    }

    if(estado.telaAtual === "poltronas" && estado.viagemSelecionada){
      mostrarTela("poltronas");
    }else if(estado.telaAtual === "comprovante" && estado.textoRecibo){
      mostrarTela("comprovante");
    }else{
      mostrarTela("viagens");
    }
  }catch(e){
    console.error("Erro ao restaurar estado:", e);
    mostrarTela("viagens");
  }

  const estadoAtual = getEstadoSalvo();

  if(pedidoPixAtual && estadoAtual.pixBoxDisplay === "block"){
    iniciarVerificacaoPixPassagem(pedidoPixAtual);
  }

  restaurandoEstado = false;
  salvarEstadoParcial();
}

["tipoViagem","formaPagamento","nome","cpfRg","whatsapp"].forEach(id => {
  const el = document.getElementById(id);
  if(!el) return;
  el.addEventListener("input", () => salvarEstadoParcial());
  el.addEventListener("change", () => salvarEstadoParcial());
});

window.addEventListener("beforeunload", () => {
  salvarEstadoParcial();
});

document.addEventListener("visibilitychange", () => {
  if(document.visibilityState === "visible"){
    const estado = getEstadoSalvo();
    const pedido = pedidoPixAtual || estado.pedidoPixAtual;
    if(pedido){
      iniciarVerificacaoPixPassagem(pedido);
    }
  }
});

document.getElementById("dataIda").addEventListener("change", async () => {
  setMsg("");
  salvarEstadoParcial();
  await renderizarListaViagens();
});

document.getElementById("dataVolta").addEventListener("change", () => {
  setMsg("");
  if(!viagemAtual){
    salvarEstadoParcial();
    return;
  }

  const tipoViagem = document.getElementById("tipoViagem").value;
  const dataVolta = document.getElementById("dataVolta").value;

  if(tipoViagem === "ida_volta" && dataVolta && !viagemRodaNaData(viagemAtual, dataVolta)){
    setMsg(`A volta não roda nesse dia. Dias disponíveis: ${viagemAtual?.dias || "-"}.`, "erro");
    return;
  }

  const valorBox = document.getElementById("valorViagem");
  if(!valorBox.classList.contains("hidden")){
    valorBox.innerHTML = `Valor da passagem: <b>R$ ${calcularValorTotal().toFixed(2)}</b>`;
  }

  salvarEstadoParcial();
});

(async function init(){
  restaurandoEstado = true;

  document.getElementById("dataIda").value = hojeLocalISO();
  document.getElementById("dataVolta").value = hojeLocalISO();

  mostrarTela("viagens");

  const ok = await resolverAppId();
  if(ok){
    await carregarConfigLoja();
    await carregarViagens();
  }else{
    document.getElementById("listaViagens").innerHTML = `<div class="vazio">Negócio não identificado.</div>`;
    restaurandoEstado = false;
    return;
  }

  await restaurarEstadoSalvo();

  if(!viagemSelecionada){
    await renderizarListaViagens();
  }
})();
</script>

