async function carregarPoltronas(){
  if(!viagemSelecionada) return;

  const estado = getEstadoSalvo();

  const { data: viagem } = await client
    .from("viagens_passagens")
    .select("id, veiculo_id")
    .eq("id", viagemSelecionada)
    .single();

  if(!viagem?.veiculo_id) return;

  const { data: veiculo } = await client
    .from("veiculos_passagens")
    .select("*")
    .eq("id", viagem.veiculo_id)
    .single();

  const total = veiculo?.total_poltronas || 20;
  const dataIda = document.getElementById("dataIda").value;

  let query = client
    .from("reservas_passagens")
    .select("poltrona, status, data_viagem")
    .eq("viagem_id", viagemSelecionada);

  if(dataIda){
    query = query.eq("data_viagem", dataIda);
  }

  const { data: reservas } = await query;

  const ocupadas = (reservas || [])
    .filter(r => {
      const status = String(r.status || "").toLowerCase().trim();
      return status !== "cancelado" && status !== "cancelada";
    })
    .map(r => Number(r.poltrona));

  const div = document.getElementById("poltronas");
  div.innerHTML = "";

  let numero = 1;

  while(numero <= total){
    const row = document.createElement("div");
    row.className = "linha-onibus";

    for(let i = 0; i < 5; i++){
      if(i === 2){
        const corredor = document.createElement("div");
        corredor.className = "corredor";
        corredor.innerText = "";
        row.appendChild(corredor);
        continue;
      }

      if(numero > total){
        const vazio = document.createElement("div");
        vazio.style.visibility = "hidden";
        row.appendChild(vazio);
        continue;
      }

      const atual = numero;
      const btn = document.createElement("div");
      btn.innerText = atual;

      if(ocupadas.includes(atual)){
        btn.className = "poltrona ocupado";
      }else{
        btn.className = "poltrona livre";

        if(String(estado.poltronaSelecionada || "") === String(atual) &&
           String(estado.viagemSelecionada || "") === String(viagemSelecionada) &&
           String(estado.dataIda || "") === String(dataIda)){
          btn.classList.add("selecionado");
          poltronaSelecionada = atual;
        }

        btn.onclick = () => {
          document.querySelectorAll(".poltrona").forEach(p => p.classList.remove("selecionado"));
          btn.classList.add("selecionado");
          poltronaSelecionada = atual;
          salvarEstadoParcial();
        };
      }

      row.appendChild(btn);
      numero++;
    }

    div.appendChild(row);
  }
}

async function uploadImagem(file, pasta){
  if(!file) return "";

  const extensao =
    file.name?.split(".").pop()?.toLowerCase() ||
    (file.type === "image/png" ? "png" : "jpg");

  const nome = `${Date.now()}-${Math.random().toString(36).slice(2)}.${extensao}`;
  const path = `${app_id}/${pasta}/${nome}`;

  const { data, error } = await client.storage
    .from("documentos")
    .upload(path, file, {
      upsert: true,
      contentType: file.type || "image/jpeg"
    });

  if(error) throw error;

  return client.storage
    .from("documentos")
    .getPublicUrl(data.path).data.publicUrl;
}

