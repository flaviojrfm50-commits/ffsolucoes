async function verificarStatusPagamentoPassagem(pedidoId){
  try{
    const { data, error } = await client
      .from("pedidos")
      .select("pagamento_status, status")
      .eq("id", pedidoId)
      .single();

    if(error || !data) return;

    const statusPagamento = String(data.pagamento_status || "").toLowerCase();

    if(statusPagamento === "approved"){
      setMsg("✅ Pagamento confirmado com sucesso.");
      document.getElementById("pixBox").style.display = "none";

      if(verificadorPixPassagem){
        clearInterval(verificadorPixPassagem);
        verificadorPixPassagem = null;
      }

      pedidoPixAtual = null;

      const dataIda = document.getElementById("dataIda").value;
      const tipoViagem = document.getElementById("tipoViagem").value;
      const dataVolta = document.getElementById("dataVolta").value;

      await client
        .from("reservas_passagens")
        .update({ status: "pago" })
        .eq("viagem_id", viagemSelecionada)
        .eq("poltrona", poltronaSelecionada)
        .eq("data_viagem", dataIda);

      if(tipoViagem === "ida_volta" && dataVolta){
        await client
          .from("reservas_passagens")
          .update({ status: "pago" })
          .eq("viagem_id", viagemSelecionada)
          .eq("poltrona", poltronaSelecionada)
          .eq("data_viagem", dataVolta);
      }

      mostrarComprovanteReserva();
      salvarEstadoParcial({ pedidoPixAtual: null, telaAtual: "comprovante" });
      poltronaSelecionada = null;
      await carregarPoltronas();
      return;
    }

    if(statusPagamento === "pending"){
      setMsg("⏳ PIX gerado. Aguardando pagamento...");
      return;
    }

    if(statusPagamento === "rejected" || statusPagamento === "cancelled"){
      setMsg("❌ Pagamento não aprovado.", "erro");

      if(verificadorPixPassagem){
        clearInterval(verificadorPixPassagem);
        verificadorPixPassagem = null;
      }
    }
  }catch(e){
    console.error("Erro verificar pagamento:", e);
  }
}

function formatarDataPadrao(dataISO){
  if(!dataISO) return "";

  const partes = String(dataISO).split("-");
  if(partes.length === 3){
    const [ano, mes, dia] = partes;
    return `${dia}/${mes}/${ano}`;
  }

  return dataISO;
}

function dataURLToBlob(dataURL){
  const arr = dataURL.split(",");
  const mime = arr[0].match(/:(.*?);/)[1];
  const bstr = atob(arr[1]);
  let n = bstr.length;
  const u8arr = new Uint8Array(n);

  while(n--){
    u8arr[n] = bstr.charCodeAt(n);
  }

  return new Blob([u8arr], { type: mime });
}

async function gerarImagemReciboComQR(){
  const texto = document.getElementById("textoRecibo").value || "";
  const qrSrc = document.getElementById("qrReservaImg").src || "";

  if(!texto){
    throw new Error("Recibo vazio.");
  }

  const canvas = document.createElement("canvas");
  const ctx = canvas.getContext("2d");

  const largura = 900;
  const altura = 1300;
  canvas.width = largura;
  canvas.height = altura;

  ctx.fillStyle = "#ffffff";
  ctx.fillRect(0, 0, largura, altura);

  ctx.fillStyle = "#111111";
  ctx.font = "bold 34px Arial";
  ctx.fillText("FF TRANSPORTE", 40, 60);

  ctx.font = "24px Arial";
  ctx.fillText("Comprovante de Reserva", 40, 105);

  const qrImg = new Image();
  qrImg.crossOrigin = "anonymous";

  await new Promise((resolve, reject) => {
    qrImg.onload = resolve;
    qrImg.onerror = reject;
    qrImg.src = qrSrc;
  });

  ctx.drawImage(qrImg, largura - 300, 40, 220, 220);

  ctx.font = "22px Arial";
  ctx.fillStyle = "#222222";

  const linhas = texto.split("\n");
  let y = 300;
  const x = 40;
  const maxWidth = largura - 80;

  function quebrarLinha(str, larguraMax){
    const palavras = String(str).split(" ");
    const saida = [];
    let linha = "";

    for(const palavra of palavras){
      const teste = linha ? `${linha} ${palavra}` : palavra;
      if(ctx.measureText(teste).width > larguraMax){
        if(linha) saida.push(linha);
        linha = palavra;
      }else{
        linha = teste;
      }
    }

    if(linha) saida.push(linha);
    return saida.length ? saida : [""];
  }

  for(const linha of linhas){
    const partes = quebrarLinha(linha, maxWidth);
    for(const parte of partes){
      ctx.fillText(parte, x, y);
      y += 34;
    }
  }

  return canvas.toDataURL("image/png");
}

