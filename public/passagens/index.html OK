      const a = document.getElementById("checkoutLink");
      a.href = link;
      a.classList.remove("hidden");

      setMsg("Pagamento criado. Abra o link, pague e depois volte aqui.");
      salvarEstadoParcial({ pedidoPixAtual: pedidoId, telaAtual: "poltronas" });

      window.open(link, "_blank");
      return;
    }

    setMsg("Forma de pagamento inválida.", "erro");
  }catch(e){
    console.error(e);
    setMsg(e.message || "Erro ao processar pagamento.", "erro");
  }
}

function copiarPix(){
  const txt = document.getElementById("pixCopiaCola").value || "";
  if(!txt) return;
  navigator.clipboard.writeText(txt)
    .then(() => setMsg("Código PIX copiado."))
    .catch(() => setMsg("Não foi possível copiar o código PIX.", "erro"));
}

function copiarRecibo(){
  const txt = document.getElementById("textoRecibo").value || "";
  if(!txt) return;

  navigator.clipboard.writeText(txt)
    .then(() => alert("Recibo copiado com sucesso."))
    .catch(() => alert("Não foi possível copiar o recibo."));
}

async function baixarPDFRecibo(){
  const txt = document.getElementById("textoRecibo").value || "";
  const qrSrc = document.getElementById("qrReservaImg").src || "";

  if(!txt){
    alert("Recibo vazio.");
    return;
  }

  try{
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    doc.setFont("helvetica", "bold");
    doc.setFontSize(16);
    doc.text("FF TRANSPORTE - COMPROVANTE", 15, 20);

    if(qrSrc){
      doc.addImage(qrSrc, "PNG", 145, 15, 45, 45);
    }

    doc.setFont("helvetica", "normal");
    doc.setFontSize(12);

    const linhas = doc.splitTextToSize(txt, 120);
    doc.text(linhas, 15, 35);

    doc.save(`recibo-${codigoReservaGlobal || "passagem"}.pdf`);
  }catch(e){
    console.error(e);
    alert("Não foi possível gerar o PDF com QR.");
  }
}

