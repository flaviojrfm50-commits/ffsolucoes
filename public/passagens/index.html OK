<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FF Transporte</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

<style>
*{box-sizing:border-box}
body{
  background:#07122b;
  color:#fff;
  font-family:Arial,sans-serif;
  margin:0;
}
.topo{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:14px 18px;
  background:#020617;
  font-size:18px;
  font-weight:bold;
}
.container{
  display:flex;
  gap:28px;
  padding:36px 20px;
  justify-content:center;
  flex-wrap:wrap;
}
.card{
  background:#1e293b;
  padding:22px;
  border-radius:22px;
  width:520px;
  max-width:100%;
}
.card h3{
  margin:0 0 14px 0;
  font-size:28px;
}
.subtitulo{
  margin:24px 0 10px;
  font-size:22px;
  font-weight:bold;
}
.label{
  margin-top:12px;
  font-size:14px;
  opacity:.9;
}
select,input,button,textarea{
  width:100%;
  padding:14px 16px;
  margin-top:10px;
  border-radius:12px;
  border:none;
  font-size:16px;
}
button{
  background:#4b83ec;
  color:#fff;
  font-weight:bold;
  cursor:pointer;
}
button:hover{opacity:.95}
.lista-viagens{margin-top:18px}
.item-viagem{
  padding:12px 10px;
  border-bottom:1px solid rgba(255,255,255,.08);
  cursor:pointer;
  font-size:22px;
}
.item-viagem:hover{
  background:rgba(255,255,255,.03);
  border-radius:10px;
}
.item-viagem.ativa{
  background:rgba(59,130,246,.15);
  border-radius:10px;
}
.item-viagem small{
  display:block;
  margin-top:4px;
  opacity:.75;
  font-size:13px;
}
.poltronas{
  background:#020617;
  padding:14px;
  border-radius:16px;
}
.motorista{
  text-align:center;
  background:#475569;
  padding:6px;
  border-radius:6px;
  font-size:18px;
  margin-bottom:12px;
}
.linha-onibus{
  display:grid;
  grid-template-columns:1fr 1fr 36px 1fr 1fr;
  gap:10px;
  margin-top:10px;
}
.corredor{
  text-align:center;
  opacity:.35;
  padding-top:10px;
}
.poltrona{
  padding:12px 0;
  border-radius:10px;
  text-align:center;
  cursor:pointer;
  font-weight:bold;
  font-size:18px;
}
.livre{background:#22c55e}
.ocupado{background:#ef4444}
.selecionado{background:#facc15;color:#111}
.vazio{opacity:.8;padding:12px 0}
.valor-box{
  margin-top:12px;
  background:#111827;
  border-radius:12px;
  padding:12px;
  font-size:18px;
}
.info-viagem{
  margin-top:12px;
  font-size:15px;
  opacity:.9;
}
.msg{
  margin-top:12px;
  padding:12px;
  border-radius:12px;
  font-size:14px;
}
.msg.erro{background:#7f1d1d}
.msg.ok{background:#14532d}
.pix-box{
  margin-top:14px;
  padding:14px;
  background:#111827;
  border-radius:14px;
  display:none;
}
.pix-box img{
  width:100%;
  max-width:260px;
  background:#fff;
  padding:10px;
  border-radius:12px;
  display:block;
  margin:10px auto;
}
.pix-copia{
  width:100%;
  min-height:88px;
  margin-top:10px;
  border-radius:10px;
  border:none;
  padding:10px;
  resize:vertical;
}
.link-btn{
  display:block;
  text-align:center;
  text-decoration:none;
  margin-top:10px;
  background:#22c55e;
  color:#fff;
  padding:12px;
  border-radius:10px;
  font-weight:bold;
}
.hidden{display:none!important}
.btn-voltar{
  background:#ef4444;
  margin-bottom:12px;
}
.comprovante-box{
  background:#111827;
  border-radius:16px;
  padding:16px;
}
.comprovante-box h4{
  margin:0 0 12px 0;
  font-size:22px;
}
.comprovante-linha{
  margin-top:6px;
  font-size:15px;
  line-height:1.6;
}
.recibo-texto{
  width:100%;
  min-height:190px;
  background:#0f172a;
  color:#fff;
}
.botoes-comprovante{
  display:grid;
  gap:10px;
  margin-top:14px;
}
@media (max-width:700px){
  .topo{
    flex-direction:column;
    gap:6px;
    text-align:center;
  }
  .container{
    padding:18px 12px;
  }
  .card h3{
    font-size:24px;
  }
  .item-viagem{
    font-size:19px;
  }
}
</style>
</head>

<body>

<div class="topo">
  <div id="nomeLoja">FF TRANSPORTE</div>
  <div>São Raimundo Nonato - PI</div>
</div>

<div class="container">

  <div class="card" id="telaViagens">
    <h3>Tipo de Viagem</h3>

    <select id="tipoViagem" onchange="atualizarCamposData()">
      <option value="ida">Somente Ida</option>
      <option value="ida_volta">Ida e Volta</option>
    </select>

    <div class="label">Data de ida</div>
    <input type="date" id="dataIda">

    <div id="boxDataVolta" class="hidden">
      <div class="label">Data de volta</div>
      <input type="date" id="dataVolta">
    </div>

    <div class="subtitulo">Viagens disponíveis</div>
    <div id="listaViagens" class="lista-viagens"></div>
  </div>

  <div class="card hidden" id="telaPoltronas">
    <button class="btn-voltar" onclick="voltarParaViagens()">← Voltar para viagens</button>

    <h3>Poltronas</h3>

    <div class="poltronas">
      <div class="motorista">MOTORISTA</div>
      <div id="poltronas"></div>
    </div>

    <div id="infoViagem" class="info-viagem"></div>
    <div id="valorViagem" class="valor-box hidden"></div>

    <select id="formaPagamento">
      <option value="">Forma de pagamento</option>
      <option value="PIX">PIX</option>
      <option value="cartao">Cartão / Mercado Pago</option>
    </select>

    <input type="text" id="nome" placeholder="Nome completo">
    <input type="text" id="cpfRg" placeholder="CPF ou RG">
    <input type="text" id="whatsapp" placeholder="WhatsApp">

    <label class="label">Foto do documento</label>
    <input type="file" id="fotoRg" accept="image/*" capture="environment">

    <label class="label">Selfie</label>

    <div id="boxSelfie" style="position:relative;display:none;margin-top:10px;">
      <video id="videoSelfie" autoplay playsinline muted style="width:100%;border-radius:12px;"></video>

      <div style="
        position:absolute;
        top:50%;
        left:50%;
        transform:translate(-50%,-50%);
        width:200px;
        height:200px;
        border-radius:50%;
        pointer-events:none;
        box-shadow:0 0 20px rgba(34,197,94,0.4);
      "></div>

      <div style="
        position:absolute;
        inset:0;
        background:rgba(0,0,0,0.5);
        border-radius:12px;
        mask: radial-gradient(circle 100px at center, transparent 99%, black 100%);
        -webkit-mask: radial-gradient(circle 100px at center, transparent 99%, black 100%);
        pointer-events:none;
      "></div>
    </div>

    <canvas id="canvasSelfie" style="display:none;"></canvas>

    <button type="button" id="btnAbrirSelfie" onclick="abrirCameraSelfie()">Abrir câmera frontal</button>
    <button type="button" id="btnCapturarSelfie" onclick="capturarSelfie()" style="display:none;">Capturar selfie</button>

    <img id="previewSelfie" style="width:100%;border-radius:12px;display:none;margin-top:10px;">

    <button onclick="pagarEReservar()">Pagar e Reservar</button>
    <button type="button" onclick="forcarVerificacao()" style="background:#22c55e;">Já paguei</button>

    <div id="mensagem"></div>

    <div id="pixBox" class="pix-box">
      <h4 style="margin:0 0 10px 0;">Pagamento PIX</h4>
      <div id="pixValor"></div>
      <img id="pixQrImg" alt="QR Code PIX">
      <textarea id="pixCopiaCola" class="pix-copia" readonly></textarea>
      <button onclick="copiarPix()">Copiar código PIX</button>
    </div>

    <a id="checkoutLink" class="link-btn hidden" target="_blank" rel="noopener">
      Abrir pagamento no Mercado Pago
    </a>
  </div>

  <div class="card hidden" id="telaComprovante">
    <h3>Comprovante</h3>

    <div class="comprovante-box">
      <h4>Comprovante de Reserva</h4>

      <div id="comprovanteVisual" class="comprovante-linha"></div>

      <img id="qrReservaImg" alt="QR Code da Reserva" style="width:100%;max-width:260px;background:#fff;padding:10px;border-radius:12px;display:block;margin:14px auto;">

      <textarea id="textoRecibo" class="recibo-texto" readonly></textarea>

      <div class="botoes-comprovante">
  <button onclick="copiarRecibo()">Copiar recibo</button>
  <button onclick="baixarPDFRecibo()">Baixar PDF do recibo</button>
  <button onclick="compartilharReciboComQR()">Compartilhar recibo com QR</button>
  <a id="btnWhatsRecibo" class="link-btn" target="_blank" rel="noopener">Enviar texto no WhatsApp</a>
  <button onclick="novaCompra()">Nova compra</button>
</div>
    </div>
  </div>

</div>

<script>
const client = window.supabase.createClient(
  "https://pdajixsoowcyhnjwhgpc.supabase.co",
  "sb_publishable_LatlFlcxk6IchHe3RNmfwA_9Oq4EsZw"
);

const params = new URLSearchParams(location.search);
const app_id_url = params.get("app_id");
const slug = params.get("slug");

const STORAGE_KEY = "ff_passagens_tela_fixa_v2";

let app_id = null;
let configLoja = null;
let viagemSelecionada = null;
let poltronaSelecionada = null;
let viagemAtual = null;
let codigoReservaGlobal = null;
let viagensCache = [];
let verificadorPixPassagem = null;
let streamSelfie = null;
let pedidoPixAtual = null;
let selfieBlob = null;
let ultimoTextoRecibo = "";
let telaAtual = "viagens";
let restaurandoEstado = false;

function hojeLocalISO(){
  const d = new Date();
  const off = d.getTimezoneOffset();
  const local = new Date(d.getTime() - off * 60000);
  return local.toISOString().slice(0, 10);
}

function agoraLocal(){
  return new Date();
}

function montarDataHoraLocal(dataISO, horaStr){
  if(!dataISO || !horaStr) return null;

  const [ano, mes, dia] = dataISO.split("-").map(Number);
  const partesHora = String(horaStr).trim().split(":");
  const hora = Number(partesHora[0] || 0);
  const minuto = Number(partesHora[1] || 0);

  return new Date(ano, mes - 1, dia, hora, minuto, 0, 0);
}

function viagemExpiradaParaData(viagem, dataISO){
  if(!viagem || !dataISO || !viagem.hora) return false;

  const agora = agoraLocal();
  const saida = montarDataHoraLocal(dataISO, viagem.hora);

  if(!saida || isNaN(saida.getTime())) return false;

  return agora >= saida;
}

function gerarCodigoReserva(){
  const parte1 = Date.now().toString().slice(-6);
  const parte2 = Math.random().toString(36).slice(2, 8).toUpperCase();
  return `FFP-${parte1}-${parte2}`;
}

function getEstadoSalvo(){
  try{
    return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
  }catch{
    return {};
  }
}

function salvarEstadoParcial(extra = {}){
  const atual = getEstadoSalvo();

  const novo = {
    ...atual,
    ...extra,
    telaAtual,
    viagemSelecionada,
    poltronaSelecionada,
    codigoReservaGlobal,
    pedidoPixAtual,
    tipoViagem: document.getElementById("tipoViagem")?.value || "ida",
    dataIda: document.getElementById("dataIda")?.value || "",
    dataVolta: document.getElementById("dataVolta")?.value || "",
    formaPagamento: document.getElementById("formaPagamento")?.value || "",
    nome: document.getElementById("nome")?.value || "",
    cpfRg: document.getElementById("cpfRg")?.value || "",
    whatsapp: document.getElementById("whatsapp")?.value || "",
    infoViagemHtml: document.getElementById("infoViagem")?.innerHTML || "",
    valorViagemHtml: document.getElementById("valorViagem")?.innerHTML || "",
    valorViagemHidden: document.getElementById("valorViagem")?.classList.contains("hidden") ?? true,
    pixBoxDisplay: document.getElementById("pixBox")?.style.display || "none",
    pixValorHtml: document.getElementById("pixValor")?.innerHTML || "",
    pixQrImg: document.getElementById("pixQrImg")?.src || "",
    pixCopiaCola: document.getElementById("pixCopiaCola")?.value || "",
    checkoutLinkHref: document.getElementById("checkoutLink")?.href || "",
    checkoutLinkHidden: document.getElementById("checkoutLink")?.classList.contains("hidden") ?? true,
    comprovanteVisual: document.getElementById("comprovanteVisual")?.innerHTML || "",
    qrReservaImg: document.getElementById("qrReservaImg")?.src || "",
    textoRecibo: document.getElementById("textoRecibo")?.value || "",
    ultimoTextoRecibo
  };

  localStorage.setItem(STORAGE_KEY, JSON.stringify(novo));
}

function limparEstadoSalvo(){
  localStorage.removeItem(STORAGE_KEY);
}

function setMsg(texto, tipo = "ok"){
  const box = document.getElementById("mensagem");
  if(!texto){
    box.innerHTML = "";
    return;
  }
  box.innerHTML = `<div class="msg ${tipo}">${texto}</div>`;
}

function limparPagamentoUI(){
  document.getElementById("pixBox").style.display = "none";
  document.getElementById("pixQrImg").src = "";
  document.getElementById("pixCopiaCola").value = "";
  document.getElementById("pixValor").innerHTML = "";
  document.getElementById("checkoutLink").classList.add("hidden");
  document.getElementById("checkoutLink").href = "#";
}

function limparSelecaoViagem(){
  viagemSelecionada = null;
  poltronaSelecionada = null;
  viagemAtual = null;
  document.getElementById("poltronas").innerHTML = "";
  document.getElementById("infoViagem").innerHTML = "";
  document.getElementById("valorViagem").innerHTML = "";
  document.getElementById("valorViagem").classList.add("hidden");
  limparPagamentoUI();
}

function mostrarTela(nome){
  telaAtual = nome;
  document.getElementById("telaViagens").classList.add("hidden");
  document.getElementById("telaPoltronas").classList.add("hidden");
  document.getElementById("telaComprovante").classList.add("hidden");

  if(nome === "viagens") document.getElementById("telaViagens").classList.remove("hidden");
  if(nome === "poltronas") document.getElementById("telaPoltronas").classList.remove("hidden");
  if(nome === "comprovante") document.getElementById("telaComprovante").classList.remove("hidden");

  if(!restaurandoEstado){
    salvarEstadoParcial();
  }
}

function voltarParaViagens(){
  mostrarTela("viagens");
}

function atualizarCamposData(){
  const tipo = document.getElementById("tipoViagem").value;
  const boxVolta = document.getElementById("boxDataVolta");
  const dataVolta = document.getElementById("dataVolta");

  if(tipo === "ida_volta"){
    boxVolta.classList.remove("hidden");
  }else{
    boxVolta.classList.add("hidden");
    dataVolta.value = "";
  }

  salvarEstadoParcial();

  if(!restaurandoEstado){
    renderizarListaViagens();
  }
}

function nomeDiaSemana(dataISO){
  if(!dataISO) return "";
  const [ano, mes, dia] = dataISO.split("-").map(Number);
  const data = new Date(ano, mes - 1, dia);
  const dias = ["Dom","Seg","Ter","Qua","Qui","Sex","Sab"];
  return dias[data.getDay()];
}

function normalizarDia(txt){
  return String(txt || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .slice(0,3);
}

function viagemRodaNaData(viagem, dataISO){
  if(!viagem || !dataISO) return false;

  const diaEscolhido = normalizarDia(nomeDiaSemana(dataISO));
  const diasViagem = String(viagem.dias || "")
    .split(",")
    .map(v => normalizarDia(v))
    .filter(Boolean);

  if(!diasViagem.length) return true;
  return diasViagem.includes(diaEscolhido);
}

function calcularValorTotal(){
  const tipoViagem = document.getElementById("tipoViagem").value;
  const valorBase = Number(viagemAtual?.valor || 0);
  return tipoViagem === "ida_volta" ? valorBase * 2 : valorBase;
}

async function resolverAppId(){
  if(app_id_url){
    app_id = app_id_url;
    return true;
  }

  if(slug){
    const { data, error } = await client
      .from("apps")
      .select("id")
      .eq("slug", slug)
      .maybeSingle();

    if(error || !data?.id) return false;

    app_id = data.id;
    return true;
  }

  return false;
}

async function carregarConfigLoja(){
  if(!app_id) return null;

  const { data, error } = await client
    .from("config_site")
    .select("*")
    .eq("app_id", app_id)
    .maybeSingle();

  if(error){
    console.error("Erro config_site:", error);
    return null;
  }

  configLoja = data || null;

  if(configLoja?.nome_site){
    document.getElementById("nomeLoja").innerText = configLoja.nome_site;
  }

  return configLoja;
}

async function abrirCameraSelfie(){
  try{
    if(streamSelfie){
      streamSelfie.getTracks().forEach(t => t.stop());
    }

    streamSelfie = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: "user" },
      audio: false
    });

    const video = document.getElementById("videoSelfie");
    video.srcObject = streamSelfie;

    document.getElementById("boxSelfie").style.display = "block";
    document.getElementById("btnCapturarSelfie").style.display = "block";
  }catch(e){
    console.error(e);
    setMsg("Não foi possível abrir a câmera frontal.", "erro");
  }
}

function capturarSelfie(){
  const video = document.getElementById("videoSelfie");
  const canvas = document.getElementById("canvasSelfie");
  const preview = document.getElementById("previewSelfie");

  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;

  const ctx = canvas.getContext("2d");
  ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

  canvas.toBlob(blob => {
    selfieBlob = blob;
    preview.src = URL.createObjectURL(blob);
    preview.style.display = "block";
  }, "image/jpeg", 0.9);

  if(streamSelfie){
    streamSelfie.getTracks().forEach(t => t.stop());
    streamSelfie = null;
  }

  document.getElementById("boxSelfie").style.display = "none";
  document.getElementById("btnCapturarSelfie").style.display = "none";
}

async function carregarViagens(){
  const lista = document.getElementById("listaViagens");
  lista.innerHTML = "";
  setMsg("");

  const ok = await resolverAppId();

  if(!ok || !app_id){
    lista.innerHTML = `<div class="vazio">Negócio não identificado.</div>`;
    return;
  }

  await carregarConfigLoja();

  const { data, error } = await client
    .from("viagens_passagens")
    .select("id, rota, hora, dias, valor, veiculo_id")
    .eq("app_id", app_id)
    .order("id", { ascending: false });

  if(error){
    console.error(error);
    lista.innerHTML = `<div class="vazio">Erro ao carregar viagens.</div>`;
    return;
  }

  viagensCache = data || [];
}

async function renderizarListaViagens(){
  const lista = document.getElementById("listaViagens");
  const dataIda = document.getElementById("dataIda").value;
  const estado = getEstadoSalvo();

  lista.innerHTML = "";

  if(!restaurandoEstado){
    limparSelecaoViagem();
  }

  if(!viagensCache.length){
    lista.innerHTML = `<div class="vazio">Nenhuma viagem cadastrada.</div>`;
    return;
  }

  const viagensFiltradas = dataIda
    ? viagensCache.filter(v =>
        viagemRodaNaData(v, dataIda) &&
        !viagemExpiradaParaData(v, dataIda)
      )
    : viagensCache;

  if(!viagensFiltradas.length){
    lista.innerHTML = `<div class="vazio">Nenhuma viagem disponível para a data escolhida.</div>`;
    return;
  }

  for(const v of viagensFiltradas){
    let nomeVeiculo = "";

    if(v.veiculo_id){
      const { data: veiculo } = await client
        .from("veiculos_passagens")
        .select("nome")
        .eq("id", v.veiculo_id)
        .maybeSingle();

      nomeVeiculo = veiculo?.nome || "";
    }

    const div = document.createElement("div");
    div.className = "item-viagem";
    div.dataset.id = v.id;
    div.innerHTML = `
      ${v.rota || ""} - ${v.hora || ""}
      ${nomeVeiculo ? `<small>${nomeVeiculo}</small>` : ""}
      ${v.dias ? `<small>Dias: ${v.dias}</small>` : ""}
      ${v.valor !== null && v.valor !== undefined ? `<small>Valor: R$ ${Number(v.valor).toFixed(2)}</small>` : ""}
    `;
    div.onclick = () => selecionarViagem(v.id);
    if(String(estado.viagemSelecionada || "") === String(v.id)){
      div.classList.add("ativa");
    }
    lista.appendChild(div);
  }
}

async function selecionarViagem(id, manterTela = false){
  viagemSelecionada = id;
  if(!restaurandoEstado){
    poltronaSelecionada = null;
    limparPagamentoUI();
  }
  setMsg("");

  document.querySelectorAll(".item-viagem").forEach(el => {
    el.classList.toggle("ativa", el.dataset.id === String(id));
  });

  const { data: viagem, error } = await client
    .from("viagens_passagens")
    .select("*")
    .eq("id", id)
    .single();

  if(error || !viagem){
    console.error(error);
    setMsg("Erro ao carregar a viagem.", "erro");
    return;
  }

  const dataIda = document.getElementById("dataIda").value;

  if(dataIda && viagemExpiradaParaData(viagem, dataIda)){
    setMsg(`Essa viagem de hoje às ${viagem.hora} já saiu e não pode mais ser vendida.`, "erro");
    if(!restaurandoEstado){
      limparSelecaoViagem();
      await renderizarListaViagens();
    }
    return;
  }

  if(dataIda && !viagemRodaNaData(viagem, dataIda)){
    setMsg(`Essa viagem não roda na data escolhida. Dias disponíveis: ${viagem.dias || "-"}.`, "erro");
    if(!restaurandoEstado){
      limparSelecaoViagem();
    }
    return;
  }

  viagemAtual = viagem;

  document.getElementById("infoViagem").innerHTML =
